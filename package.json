{
  "name": "klawpay",
  "version": "1.0.0",
  "description": "OpenClaw plugin — payment & refund client powered by ClawRevert and OWS",
  "module": "src/index.ts",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "bun run --watch src/index.ts",
    "start": "bun run src/index.ts",
    "pay": "bun run src/cli.ts"
  },
  "dependencies": {
    "hono": "^4.12.10",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/bun": "latest"
