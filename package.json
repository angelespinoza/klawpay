{
  "name": "klawpay",
  "version": "1.0.0",
  "description": "OpenClaw plugin — accept crypto payments and process refunds via ClawRevert and OWS",
  "module": "src/entry.ts",
  "main": "src/entry.ts",
  "type": "module",
  "scripts": {
    "dev": "bun run --watch src/index.ts",
    "start": "bun run src/index.ts",
    "pay": "bun run src/cli.ts"
  },
  "files": [
    "src/",
    "dashboard/",
    "docs/",
    "openclaw.plugin.json"
  ],
  "keywords": [
    "openclaw",
    "openclaw-plugin",
    "crypto",
    "payments",
    "refunds",
    "ows",
    "xrpl",
    "sui",
    "solana",
    "base"
  ],
  "author": "Angel Espinoza",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/angelespinoza/klawpay"
  },
  "dependencies": {
    "hono": "^4.12.10",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/bun": "latest"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "openclaw": {
    "plugin": true,
    "entry": "src/entry.ts",
    "skills": [
      "src/skills/payments.md",
      "src/skills/refunds.md"
    ]
  }
}
