{
  "id": "klawpay",
  "name": "KlawPay",
  "description": "Accept crypto payments and process refunds across XRPL, Sui, Solana, and EVM chains — powered by ClawRevert and OWS",
  "version": "1.0.0",
  "configSchema": {
    "type": "object",
    "additionalProperties": false,
    "properties": {
      "clawrevertUrl": {
        "type": "string",
        "description": "ClawRevert API base URL",
        "default": "https://clawrevert-production.up.railway.app"
      },
      "defaultChain": {
        "type": "string",
        "enum": ["xrpl", "sui", "solana", "base", "ethereum"],
        "default": "xrpl",
        "description": "Default blockchain for payments"
      },
      "language": {
        "type": "string",
        "enum": ["en", "es", "pt"],
        "default": "en",
        "description": "Default response language"
      }
    }
  },
  "contracts": {
    "tools": ["klawpay_pay", "klawpay_refund", "klawpay_audit", "klawpay_health"]
  },
  "skills": ["src/skills"]
}
